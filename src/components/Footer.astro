---
import { Clock, Instagram, MapPin, Phone } from "lucide-astro";

const navLinks = [
  { label: "Menu", href: "/menu" },
  { label: "Reservations", href: "/reservations" },
  { label: "Private Dining", href: "/private-dining" },
  { label: "About", href: "/about" },
];
---

<footer class="mt-16 border-t border-white/10 pt-12 pb-8">
	<div class="grid grid-cols-1 gap-10 md:grid-cols-4">
		{/* Brand */}
		<div class="md:col-span-1">
			<div class="font-serif text-xl tracking-wide text-linen">
				Ember <span class="text-ember">&amp;</span> Kitchen
			</div>
			<p class="mt-3 text-sm leading-relaxed text-ash">
				A sanctuary of ember-cooked cuisine in the heart of New York City.
			</p>
			<div class="mt-4 flex items-center gap-3">
				<a
					href="https://instagram.com"
					aria-label="Instagram"
					target="_blank"
					rel="noopener noreferrer"
					class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-white/40 transition-colors hover:border-ember/50 hover:text-ember"
				>
					<Instagram size={15} />
				</a>
			</div>
		</div>

		{/* Navigate */}
		<div>
			<h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-ember">
				Navigate
			</h4>
			<ul class="space-y-2.5 text-sm text-white/50 p-0 list-none">
				{navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="transition-colors hover:text-ember-warm no-underline"
							data-astro-prefetch
						>
							{link.label}
						</a>
					</li>
				))}
			</ul>
		</div>

		{/* Hours */}
		<div>
			<h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-ember">
				Hours
			</h4>
			<ul class="space-y-2 text-sm text-white/50 p-0 list-none">
				<li class="flex items-start gap-2">
					<Clock size={13} class="mt-0.5 shrink-0 text-ember" />
					<span>
						Tue – Thu
						<br />
						<span class="text-white/30">5:30 PM – 10:00 PM</span>
					</span>
				</li>
				<li class="flex items-start gap-2">
					<Clock size={13} class="mt-0.5 shrink-0 text-ember" />
					<span>
						Fri – Sat
						<br />
						<span class="text-white/30">5:30 PM – 11:00 PM</span>
					</span>
				</li>
				<li class="flex items-start gap-2">
					<Clock size={13} class="mt-0.5 shrink-0 text-ember" />
					<span>
						Sunday
						<br />
						<span class="text-white/30">4:00 PM – 9:00 PM</span>
					</span>
				</li>
			</ul>
		</div>

		{/* Contact */}
		<div>
			<h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-ember">
				Find Us
			</h4>
			<ul class="space-y-3 text-sm text-white/50 p-0 list-none">
				<li class="flex items-start gap-2">
					<MapPin size={13} class="mt-0.5 shrink-0 text-ember" />
					<span>
						14 Driftwood Lane
						<br />
						Lower East Side, NY 10002
					</span>
				</li>
				<li class="flex items-center gap-2">
					<Phone size={13} class="shrink-0 text-ember" />
					<span>(212) 555-0174</span>
				</li>
			</ul>
		</div>
	</div>

	<div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-white/5 pt-6 text-xs text-white/20 sm:flex-row">
		<span>© 2026 Ember &amp; Kitchen. All rights reserved.</span>
		<span>14 Driftwood Lane, Lower East Side, NY</span>
	</div>
</footer>
