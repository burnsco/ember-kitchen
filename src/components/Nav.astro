---
const { pathname } = Astro.url;

const navLinks = [
  { href: "/menu", label: "Menu" },
  { href: "/reservations", label: "Reservations" },
  { href: "/private-dining", label: "Private Dining" },
  { href: "/about", label: "About" },
];

function isActive(href: string) {
  if (href === "/" && pathname !== "/") return false;
  return pathname.startsWith(href);
}
---

<nav class="border-b border-white/10 pb-5">
	<div class="flex items-center justify-between gap-4">
		<a
			href="/"
			class="font-serif text-2xl tracking-wide text-linen no-underline"
		>
			Ember <span class="text-ember">&amp;</span> Kitchen
		</a>

		<div class="hidden gap-8 text-sm font-medium text-white/60 md:flex">
			{navLinks.map(({ href, label }) => (
				<a
					href={href}
					class={`transition-colors no-underline ${isActive(href) ? "text-ember-warm" : "hover:text-ember-warm"}`}
					data-astro-prefetch
				>
					{label}
				</a>
			))}
		</div>

		<div class="flex items-center gap-3">
			<a
				href="/reservations"
				class="rounded-full bg-ember px-5 py-2.5 text-sm font-bold uppercase tracking-[0.1em] text-white transition-colors hover:bg-ember-glow no-underline"
				data-astro-prefetch
			>
				Reserve a Table
			</a>
			<button
				id="mobile-nav-toggle"
				aria-label="Toggle navigation menu"
				aria-expanded="false"
				class="flex h-9 w-9 flex-col items-center justify-center gap-[5px] rounded-lg md:hidden"
			>
				<span class="hamburger-bar block h-px w-5 bg-white/70 transition-all duration-300 origin-center"></span>
				<span class="hamburger-bar block h-px w-5 bg-white/70 transition-all duration-300 origin-center"></span>
				<span class="hamburger-bar block h-px w-5 bg-white/70 transition-all duration-300 origin-center"></span>
			</button>
		</div>
	</div>

	<div id="mobile-nav" class="hidden flex-col gap-1 pt-4 md:hidden">
		{navLinks.map(({ href, label }) => (
			<a
				href={href}
				class={`block rounded-lg px-3 py-2.5 text-sm font-medium no-underline transition-colors ${isActive(href) ? "bg-ember/10 text-ember-warm" : "text-white/60 hover:bg-white/5 hover:text-ember-warm"}`}
				data-astro-prefetch
			>
				{label}
			</a>
		))}
	</div>
</nav>

<script>
	const toggle = document.getElementById("mobile-nav-toggle")!;
	const menu = document.getElementById("mobile-nav")!;
	const bars = toggle.querySelectorAll<HTMLElement>(".hamburger-bar");

	toggle.addEventListener("click", () => {
		const open = toggle.getAttribute("aria-expanded") === "true";
		toggle.setAttribute("aria-expanded", String(!open));
		menu.classList.toggle("hidden", open);
		menu.classList.toggle("flex", !open);

		// Animate to X and back
		bars.item(0)!.style.transform = open ? "" : "translateY(6px) rotate(45deg)";
		bars.item(1)!.style.opacity = open ? "" : "0";
		bars.item(2)!.style.transform = open ? "" : "translateY(-6px) rotate(-45deg)";
	});
</script>
