---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { CheckCircle2, Clock, Info, MapPin, Phone } from "lucide-astro";

const times = [
  "5:30 PM",
  "6:00 PM",
  "6:30 PM",
  "7:00 PM",
  "7:30 PM",
  "8:00 PM",
  "8:30 PM",
  "9:00 PM",
  "9:30 PM",
  "10:00 PM",
];

const occasions = [
  "",
  "Birthday",
  "Anniversary",
  "Date Night",
  "Business Dinner",
  "Celebration",
  "Other",
];

const inputClass =
  "w-full rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-linen placeholder-white/25 outline-none transition-colors focus:border-ember/60 focus:bg-white/[0.06]";

const labelClass =
  "mb-1.5 block text-xs font-medium uppercase tracking-[0.12em] text-white/40";
---

<Layout title="Reservations">
  <div class="mx-auto max-w-7xl px-6 py-7 md:px-10">
    <Nav />

    <div class="mt-12 grid grid-cols-1 gap-12 lg:grid-cols-5">
      {/* Form */}
      <div class="lg:col-span-3">
        <p class="text-xs font-bold uppercase tracking-[0.25em] text-ember">
          Secure Your Evening
        </p>
        <h1 class="mt-3 font-serif text-5xl md:text-6xl">
          Reserve a Table
        </h1>
        <p class="mt-4 text-ash leading-relaxed">
          We recommend booking at least 48 hours in advance. For same-day
          reservations, please call us directly.
        </p>

        <div id="success-message" class="hidden mt-10 rounded-3xl border border-ember/30 bg-ember/10 p-8 text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-ember/20">
            <CheckCircle2 size={24} class="text-ember" />
          </div>
          <h2 class="font-serif text-3xl">We'll see you soon.</h2>
          <p class="mt-3 text-sm text-ash">
            A confirmation has been sent to <span id="display-email" class="text-ember-warm">your email</span>. We look
            forward to welcoming you to Ember &amp; Kitchen.
          </p>
          <button
            id="reset-form"
            type="button"
            class="mt-6 text-sm text-white/40 underline hover:text-white/70 cursor-pointer"
          >
            Make another reservation
          </button>
        </div>

        <form id="reservation-form" class="mt-8 space-y-5">
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class={labelClass}>
                Full Name
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Jane Smith"
                class={inputClass}
              />
            </div>
            <div>
              <label for="email" class={labelClass}>
                Email Address
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="jane@example.com"
                class={inputClass}
              />
            </div>
          </div>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="phone" class={labelClass}>
                Phone Number
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                placeholder="(212) 555-0100"
                class={inputClass}
              />
            </div>
            <div>
              <label for="guests" class={labelClass}>
                Party Size
              </label>
              <select
                id="guests"
                name="guests"
                class={inputClass}
              >
                {Array.from({ length: 7 }, (_, i) => i + 1).map((n) => (
                  <option value={n} class="bg-hearth">
                    {n} {n === 1 ? "Guest" : "Guests"}
                  </option>
                ))}
                <option value="8+" class="bg-hearth">
                  8+ Guests (Private Dining)
                </option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="date" class={labelClass}>
                Date
              </label>
              <input
                id="date"
                name="date"
                type="date"
                required
                class={inputClass}
              />
            </div>
            <div>
              <label for="time" class={labelClass}>
                Preferred Time
              </label>
              <select
                id="time"
                name="time"
                required
                class={inputClass}
              >
                <option value="" class="bg-hearth">
                  Select a time
                </option>
                {times.map((t) => (
                  <option value={t} class="bg-hearth">
                    {t}
                  </option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label for="occasion" class={labelClass}>
              Occasion (optional)
            </label>
            <select
              id="occasion"
              name="occasion"
              class={inputClass}
            >
              {occasions.map((o) => (
                <option value={o} class="bg-hearth">
                  {o || "Select an occasion"}
                </option>
              ))}
            </select>
          </div>

          <div>
            <label for="requests" class={labelClass}>
              Special Requests
            </label>
            <textarea
              id="requests"
              name="requests"
              rows={3}
              placeholder="Dietary requirements, allergies, celebrations..."
              class={`${inputClass} resize-none`}
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-full bg-ember py-4 text-sm font-bold uppercase tracking-[0.12em] text-white transition-colors hover:bg-ember-glow cursor-pointer"
          >
            Confirm Reservation
          </button>

          <p class="flex items-center gap-1.5 text-center text-xs text-white/25 justify-center">
            <Info size={11} />
            Cancellations accepted up to 24 hours before your booking.
          </p>
        </form>
      </div>

      {/* Info Panel */}
      <div class="lg:col-span-2 space-y-5">
        {/* Hours */}
        <div class="rounded-3xl border border-white/10 bg-hearth p-6">
          <div class="mb-4 flex items-center gap-2">
            <Clock size={15} class="text-ember" />
            <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-ember">
              Hours
            </h3>
          </div>
          <ul class="space-y-3 text-sm p-0 list-none">
            {[
              { day: "Tuesday – Thursday", hours: "5:30 PM – 10:00 PM" },
              { day: "Friday – Saturday", hours: "5:30 PM – 11:00 PM" },
              { day: "Sunday", hours: "4:00 PM – 9:00 PM" },
              { day: "Monday", hours: "Closed" },
            ].map(({ day, hours }) => (
              <li class="flex justify-between">
                <span class="text-white/50">{day}</span>
                <span
                  class={
                    hours === "Closed" ? "text-white/25" : "text-ember-warm"
                  }
                >
                  {hours}
                </span>
              </li>
            ))}
          </ul>
        </div>

        {/* Location */}
        <div class="rounded-3xl border border-white/10 bg-hearth p-6">
          <div class="mb-4 flex items-center gap-2">
            <MapPin size={15} class="text-ember" />
            <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-ember">
              Location
            </h3>
          </div>
          <p class="text-sm text-white/60">14 Driftwood Lane</p>
          <p class="text-sm text-white/60">Lower East Side, NY 10002</p>
          <p class="mt-3 text-xs text-white/30">
            Valet parking available on weekends. Nearest subway: Delancey St
            (F, M, J, Z).
          </p>
        </div>

        {/* Phone */}
        <div class="rounded-3xl border border-white/10 bg-hearth p-6">
          <div class="mb-4 flex items-center gap-2">
            <Phone size={15} class="text-ember" />
            <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-ember">
              By Phone
            </h3>
          </div>
          <p class="font-serif text-2xl text-linen">
            (212) 555-0174
          </p>
          <p class="mt-2 text-xs text-white/30">
            Available daily from 2:00 PM until 30 minutes before closing.
          </p>
        </div>

        {/* Large groups note */}
        <div class="rounded-3xl bg-ember/10 border border-ember/20 p-6">
          <p class="text-sm font-medium text-ember-warm">
            Groups of 8 or more?
          </p>
          <p class="mt-1 text-xs text-white/40">
            We offer exclusive private dining rooms for larger parties.
            Contact us directly to arrange a bespoke evening.
          </p>
        </div>
      </div>
    </div>

    <Footer />
  </div>
</Layout>

<script>
  const form = document.getElementById('reservation-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message');
  const resetBtn = document.getElementById('reset-form');
  const displayEmail = document.getElementById('display-email');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const email = formData.get('email') as string;
    
    if (displayEmail) displayEmail.textContent = email;
    
    form.classList.add('hidden');
    successMessage?.classList.remove('hidden');
  });

  resetBtn?.addEventListener('click', () => {
    form.reset();
    form.classList.remove('hidden');
    successMessage?.classList.add('hidden');
  });
</script>
