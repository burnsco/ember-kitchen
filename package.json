{
  "name": "ember-kitchen",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "bun run typecheck && astro build",
    "deploy": "bun run build && npx wrangler deploy --config dist/server/wrangler.json",
    "deploy:dry-run": "bun run build && npx wrangler deploy --dry-run --config dist/server/wrangler.json",
    "cf:status": "../scripts/cf-portfolio.sh status ember-kitchen",
    "typecheck": "astro check",
    "preview": "astro preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix . && oxfmt",
    "format": "oxfmt",
    "prepare": "husky",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.0.1",
    "@astrojs/react": "^6.0.0",
    "astro": "^7.0.3",
    "lucide-astro": "^0.556.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  }
}
